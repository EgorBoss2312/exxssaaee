# Скопируйте в .env и подставьте значения. Файл .env подхватывается из каталога backend/.

# --- Языковая модель для чата (RAG уже есть; без LLM ответ = только фрагменты) ---

# Вариант 1 (приоритет): Google Gemini — ключ в https://aistudio.google.com/apikey
# Ключ всегда начинается с «AIzaSy» (латинская A в начале). Одна строка, без кавычек.
GEMINI_API_KEY=AIzaSyBhtNfwaq-zwN2eYInxD5162OCsBF9islw
# Рекомендуется актуальная модель; при квоте/ошибке 404 код перебирает запасные (см. app/services/llm.py)
GEMINI_MODEL=gemini-2.5-flash

# Вариант 2: OpenAI (если GEMINI_API_KEY не задан)
OPENAI_API_KEY=
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Вариант 3: локальная Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# --- Прочее (см. app/config.py) ---
# JWT_SECRET=
# DATABASE_URL=
# На деплое (фронт и API на разных доменах или превью-URL):
# CORS_ORIGINS=https://ваш-фронт.example.com
# CORS_ORIGIN_REGEX=https://.*\\.vercel\\.app
